#!/bin/bash
# pre-commit hook: 機密情報スキャン（Layer 0 物理ブロック）
# 2026-05-02: cybersecurity-playbook の Gitleaks 必須記載を物理化
# 依存ゼロ（grep のみ）、Gitleaks インストール済なら追加で実行

set -e

DIFF=$(git diff --cached --no-color)
VIOLATIONS=()

# 1. AWS / GCP / Azure / Anthropic / OpenAI 系キーパターン
if echo "$DIFF" | grep -qE 'AKIA[0-9A-Z]{16}'; then
  VIOLATIONS+=("AWS Access Key ID 検出")
fi
if echo "$DIFF" | grep -qE '(aws_secret_access_key|aws_access_key_id)\s*[=:]\s*["\x27]?[A-Za-z0-9/+]{20,}' -i; then
  VIOLATIONS+=("AWS credentials ハードコード値検出")
fi
if echo "$DIFF" | grep -qE 'sk-ant-[a-zA-Z0-9_\-]{30,}'; then
  VIOLATIONS+=("Anthropic API Key 検出")
fi
if echo "$DIFF" | grep -qE 'sk-[a-zA-Z0-9]{40,}'; then
  VIOLATIONS+=("OpenAI API Key 検出")
fi
if echo "$DIFF" | grep -qE 'ghp_[a-zA-Z0-9]{30,}|github_pat_[a-zA-Z0-9_]{60,}'; then
  VIOLATIONS+=("GitHub Personal Access Token 検出")
fi

# 2. 一般的な秘密情報パターン
if echo "$DIFF" | grep -qE 'BEGIN (RSA |EC |DSA |OPENSSH |PGP )?PRIVATE KEY'; then
  VIOLATIONS+=("PEM 形式秘密鍵検出")
fi
if echo "$DIFF" | grep -qE '"password"\s*:\s*"[^"]{8,}"|password\s*=\s*[^\s]{8,}' -i; then
  VIOLATIONS+=("ハードコードパスワード疑い")
fi

# 3. .env / credentials / secrets ファイル誤コミット
STAGED_FILES=$(git diff --cached --name-only)
if echo "$STAGED_FILES" | grep -qE '(^|/)\.env(\.|$)|credentials\.(json|yml|yaml)|secrets?\.(json|yml|yaml)'; then
  VIOLATIONS+="(機密ファイル誤コミット: $(echo "$STAGED_FILES" | grep -E '(^|/)\.env(\.|$)|credentials|secrets?'))"
fi

# 4. プロンプト・会話文脈混入の疑い（commit message ではなく diff から）
if echo "$DIFF" | grep -qE 'ANTHROPIC_API_KEY|OPENAI_API_KEY|CLAUDE_API_KEY' && echo "$DIFF" | grep -qE '=\s*["\x27]?[a-zA-Z0-9_\-]{20,}'; then
  VIOLATIONS+=("環境変数ハードコード疑い")
fi

# 5. Gitleaks 追加実行（インストール済の場合のみ）
if command -v gitleaks >/dev/null 2>&1; then
  if ! gitleaks protect --staged --no-banner 2>/dev/null; then
    VIOLATIONS+=("Gitleaks 検出（詳細は gitleaks protect --staged で確認）")
  fi
fi

# 違反検出時はブロック
if [ ${#VIOLATIONS[@]} -gt 0 ]; then
  echo "" >&2
  echo "🚫 commit ブロック: 機密情報の可能性を検出しました（Layer 0 物理ブロック）" >&2
  echo "" >&2
  for v in "${VIOLATIONS[@]}"; do
    echo "  - $v" >&2
  done
  echo "" >&2
  echo "対応: 該当箇所を修正してから再 commit してください" >&2
  echo "緊急回避（推奨しない）: git commit --no-verify" >&2
  echo "詳細: .claude/skills/cybersecurity-playbook.md Layer 0" >&2
  exit 1
fi

exit 0
