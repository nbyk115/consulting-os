#!/bin/bash
# commit-msg hook: コミットメッセージへの機密情報・会話文脈混入をブロック
# 2026-05-02: Theo セキュリティ警告対応（プロンプト/会話文脈混入リスク）

set -e

MSG_FILE="$1"
MSG=$(cat "$MSG_FILE")
VIOLATIONS=()

# 1. API key パターン
if echo "$MSG" | grep -qE 'sk-ant-[a-zA-Z0-9_\-]{20,}|sk-[a-zA-Z0-9]{30,}|AKIA[0-9A-Z]{16}|ghp_[a-zA-Z0-9]{30,}'; then
  VIOLATIONS+=("API Key パターンが commit message に混入")
fi

# 2. 環境変数キーワードと値の組み合わせ
if echo "$MSG" | grep -qE '(ANTHROPIC|OPENAI|CLAUDE|AWS|GITHUB)_API_KEY\s*=\s*[a-zA-Z0-9_\-]{15,}'; then
  VIOLATIONS+=("環境変数ハードコードが commit message に混入")
fi

# 3. PEM 秘密鍵
if echo "$MSG" | grep -qE 'BEGIN (RSA |EC |DSA |OPENSSH |PGP )?PRIVATE KEY'; then
  VIOLATIONS+=("PEM 秘密鍵が commit message に混入")
fi

if [ ${#VIOLATIONS[@]} -gt 0 ]; then
  echo "" >&2
  echo "🚫 commit ブロック: コミットメッセージに機密情報の可能性を検出" >&2
  echo "" >&2
  for v in "${VIOLATIONS[@]}"; do
    echo "  - $v" >&2
  done
  echo "" >&2
  echo "対応: コミットメッセージから機密情報を削除してください" >&2
  exit 1
fi

# 4. 反証チェック規律警告（CLAUDE.md ハードルール 1・2026-05-03 audit 100/100 達成施策）
ADDED_LINES=$(git diff --cached --numstat 2>/dev/null | awk '{sum+=$1} END {print sum+0}')
TOUCHED_PATHS=$(git diff --cached --name-only 2>/dev/null | grep -E '^(docs|strategy|examples)/' | head -1)
if [ -n "$TOUCHED_PATHS" ] && [ "$ADDED_LINES" -ge 50 ]; then
  if ! echo "$MSG" | grep -qE '反証|Step 1|Step 2|Step 3|残存リスク|FACT|INFERENCE|SPECULATION'; then
    echo "" >&2
    echo "⚠️  推奨: 大型コミット（${ADDED_LINES} 行追加）かつ docs/strategy/examples 配下変更に反証チェック / 出典 3 ラベル言及なし（CLAUDE.md ハードルール 1）" >&2
    echo "    対応推奨: 反証 Step 1-3 / 残存リスク / FACT/INFERENCE/SPECULATION ラベルを含める" >&2
    echo "    緊急回避: 警告のみ・コミット許可" >&2
  fi
fi

exit 0
